# Storage Mode
# local   : default. No PostgreSQL required. Uses data/local-storage.json generated from db.json.
# postgres: optional advanced mode. Uses Prisma + PostgreSQL.
EHR_STORAGE_MODE=local

# PostgreSQL (optional, only used when EHR_STORAGE_MODE=postgres)
DATABASE_URL="postgresql://postgres:YOUR_STRONG_PASSWORD_HERE@localhost:5432/dialog_ehr?schema=public"
POSTGRES_USER=postgres
# IMPORTANT: Use a strong password in production. Generate one with: openssl rand -base64 32
POSTGRES_PASSWORD=YOUR_STRONG_PASSWORD_HERE
POSTGRES_DB=dialog_ehr
POSTGRES_PORT=5432

# Authentication
# Set to `true` to require login. Set to `false` for open access (demo mode).
EHR_AUTH_REQUIRED=false

# Session secret (32+ character random string)
# Generate with: openssl rand -base64 32
SESSION_SECRET="REPLACE_WITH_RANDOM_32_CHAR_SECRET"

# Account lock settings
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=30

# Password reset token expiry
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=1

# Default demo admin account (available in local mode on first run)
# Username: admin
# Password: Admin123!
# Change it if you plan to reuse the environment.
